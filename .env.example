# Application
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-in-production-32-chars!!

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=quizgen
DB_PASSWORD=quizgen_secret
DB_NAME=quizgen
DB_SSLMODE=disable

# LLM — выберите ОДИН из вариантов ниже
# Provider: anthropic | openai | gigachat

# --- GigaChat (Sber) ---
LLM_PROVIDER=gigachat
# Authorization Key из личного кабинета developers.sber.ru (это base64-строка вида ZjU...==)
LLM_API_KEY=your-gigachat-authorization-key
LLM_MODEL=GigaChat
LLM_SCOPE=GIGACHAT_API_PERS
# Можно не задавать — будут использованы дефолты:
# LLM_BASE_URL=https://ngw.devices.sberbank.ru:9443
# LLM_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1

# --- Anthropic Claude ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5
# LLM_BASE_URL=https://api.anthropic.com

# --- OpenAI / DeepSeek ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Rate limiting (requests per user per hour)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=3600

# File upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/quizgen_uploads

# Session
SESSION_TTL_HOURS=24
